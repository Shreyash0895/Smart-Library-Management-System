import javax.swing.*;
import javax.swing.border.*;
import java.awt.*;
import java.awt.event.*;
import java.awt.image.BufferedImage;
import java.net.*;
import java.util.*;
import com.mongodb.client.*;
import com.mongodb.client.model.*;
import org.bson.Document;
import org.bson.types.ObjectId;
import javax.imageio.ImageIO;

public class StudentQRScannerPanel extends JPanel {

    private JTextField isbnField;
    private JPanel resultPanel;
    private JPanel qrDisplayPanel;
    private JLabel statusLabel;
    private String userId;

    public StudentQRScannerPanel(String userId) {
        this.userId = userId;
        setLayout(new BorderLayout(10, 10));
        setBackground(new Color(245, 245, 245));
        add(createHeaderPanel(), BorderLayout.NORTH);
        add(createMainPanel(),   BorderLayout.CENTER);
        add(createStatusBar(),   BorderLayout.SOUTH);
    }

    private JPanel createHeaderPanel() {
        JPanel panel = new JPanel(new BorderLayout());
        panel.setBackground(new Color(41, 128, 185));
        panel.setBorder(BorderFactory.createEmptyBorder(15, 20, 15, 20));
        JLabel title = new JLabel("📷  QR Book Scanner");
        title.setFont(new Font("Segoe UI", Font.BOLD, 22));
        title.setForeground(Color.WHITE);
        JLabel sub = new JLabel("Enter ISBN to get full book information and borrow");
        sub.setFont(new Font("Segoe UI", Font.PLAIN, 13));
        sub.setForeground(new Color(214, 234, 248));
        JPanel tp = new JPanel(new GridLayout(2, 1, 0, 4));
        tp.setOpaque(false);
        tp.add(title); tp.add(sub);
        panel.add(tp, BorderLayout.CENTER);
        return panel;
    }

    private JPanel createMainPanel() {
        JPanel main = new JPanel(new GridLayout(1, 2, 15, 0));
        main.setBackground(new Color(245, 245, 245));
        main.setBorder(BorderFactory.createEmptyBorder(15, 15, 15, 15));
        main.add(createLeftPanel());
        main.add(createRightScrollPane());
        return main;
    }

    private JPanel createLeftPanel() {
        JPanel panel = new JPanel(new BorderLayout(0, 12));
        panel.setOpaque(false);

        JPanel inputCard = new JPanel(new GridBagLayout());
        inputCard.setBackground(Color.WHITE);
        inputCard.setBorder(BorderFactory.createCompoundBorder(
            BorderFactory.createLineBorder(new Color(189, 195, 199), 1, true),
            BorderFactory.createEmptyBorder(20, 20, 20, 20)));

        GridBagConstraints g = new GridBagConstraints();
        g.insets = new Insets(8, 6, 8, 6);
        g.fill = GridBagConstraints.HORIZONTAL;
        g.gridwidth = 2;

        JLabel lbl = new JLabel("🔍  Enter ISBN Number", SwingConstants.CENTER);
        lbl.setFont(new Font("Segoe UI", Font.BOLD, 15));
        lbl.setForeground(new Color(41, 128, 185));
        g.gridx = 0; g.gridy = 0; inputCard.add(lbl, g);

        isbnField = new JTextField();
        isbnField.setFont(new Font("Segoe UI", Font.PLAIN, 16));
        isbnField.setHorizontalAlignment(JTextField.CENTER);
        isbnField.setBorder(BorderFactory.createCompoundBorder(
            BorderFactory.createLineBorder(new Color(41, 128, 185), 2, true),
            BorderFactory.createEmptyBorder(8, 10, 8, 10)));
        isbnField.addActionListener(e -> searchAndGenerate());
        g.gridy = 1; inputCard.add(isbnField, g);

        JButton searchBtn = makeBtn("🔍 Search & Generate QR", new Color(41, 128, 185));
        JButton clearBtn  = makeBtn("✖ Clear",                  new Color(149, 165, 166));
        JButton openBtn   = makeBtn("🌐 Open QR in Browser",    new Color(39, 174, 96));
        searchBtn.addActionListener(e -> searchAndGenerate());
        clearBtn .addActionListener(e -> clearAll());
        openBtn  .addActionListener(e -> openInBrowser());
        g.gridy = 2; inputCard.add(searchBtn, g);
        g.gridy = 3; inputCard.add(clearBtn,  g);
        g.gridy = 4; inputCard.add(openBtn,   g);

        panel.add(inputCard, BorderLayout.NORTH);

        qrDisplayPanel = new JPanel(new BorderLayout());
        qrDisplayPanel.setBackground(Color.WHITE);
        qrDisplayPanel.setBorder(BorderFactory.createCompoundBorder(
            BorderFactory.createLineBorder(new Color(189, 195, 199), 1, true),
            BorderFactory.createEmptyBorder(12, 12, 12, 12)));
        JLabel ph = new JLabel("QR code will appear here", SwingConstants.CENTER);
        ph.setFont(new Font("Segoe UI", Font.ITALIC, 13));
        ph.setForeground(new Color(190, 190, 190));
        qrDisplayPanel.add(ph, BorderLayout.CENTER);
        panel.add(qrDisplayPanel, BorderLayout.CENTER);
        return panel;
    }

    private JScrollPane createRightScrollPane() {
        resultPanel = new JPanel();
        resultPanel.setLayout(new BoxLayout(resultPanel, BoxLayout.Y_AXIS));
        resultPanel.setBackground(new Color(245, 245, 245));
        showPlaceholder();
        JScrollPane scroll = new JScrollPane(resultPanel);
        scroll.setBorder(null);
        scroll.getViewport().setBackground(new Color(245, 245, 245));
        return scroll;
    }

    private void showPlaceholder() {
        resultPanel.removeAll();
        JPanel ph = new JPanel(new GridBagLayout());
        ph.setBackground(Color.WHITE);
        ph.setBorder(BorderFactory.createCompoundBorder(
            BorderFactory.createLineBorder(new Color(189, 195, 199), 1, true),
            BorderFactory.createEmptyBorder(40, 20, 40, 20)));
        ph.setMaximumSize(new Dimension(Integer.MAX_VALUE, 300));
        JLabel l = new JLabel("📖 Book details will appear here", SwingConstants.CENTER);
        l.setFont(new Font("Segoe UI", Font.ITALIC, 14));
        l.setForeground(new Color(180, 180, 180));
        ph.add(l);
        resultPanel.add(ph);
        resultPanel.revalidate(); resultPanel.repaint();
    }

    private JPanel createStatusBar() {
        JPanel bar = new JPanel(new BorderLayout());
        bar.setBackground(new Color(236, 240, 241));
        bar.setBorder(BorderFactory.createEmptyBorder(6, 14, 6, 14));
        statusLabel = new JLabel("Ready — enter an ISBN to search");
        statusLabel.setFont(new Font("Segoe UI", Font.PLAIN, 12));
        statusLabel.setForeground(new Color(100, 100, 100));
        bar.add(statusLabel, BorderLayout.WEST);
        return bar;
    }

    private String currentISBN = "";

    private void searchAndGenerate() {
        String isbn = isbnField.getText().trim();
        if (isbn.isEmpty()) { showStatus("⚠ Please enter an ISBN", new Color(230,126,34)); return; }
        currentISBN = isbn;
        showStatus("🔄 Searching...", new Color(41, 128, 185));

        SwingWorker<Void, Void> worker = new SwingWorker<>() {
            @Override protected Void doInBackground() {
                generateQR(isbn);
                lookupBook(isbn);
                return null;
            }
        };
        worker.execute();
    }

    private void generateQR(String isbn) {
        try {
            String url = "https://api.qrserver.com/v1/create-qr-code/?size=200x200&data="
                       + URLEncoder.encode(isbn, "UTF-8") + "&margin=10";
            BufferedImage img = ImageIO.read(new URL(url));
            SwingUtilities.invokeLater(() -> {
                qrDisplayPanel.removeAll();
                if (img != null) {
                    JPanel inner = new JPanel(new BorderLayout(0, 6));
                    inner.setBackground(Color.WHITE);
                    inner.add(new JLabel(new ImageIcon(img), SwingConstants.CENTER), BorderLayout.CENTER);
                    JLabel cap = new JLabel("ISBN: " + isbn, SwingConstants.CENTER);
                    cap.setFont(new Font("Segoe UI", Font.BOLD, 11));
                    cap.setForeground(new Color(41, 128, 185));
                    inner.add(cap, BorderLayout.SOUTH);
                    qrDisplayPanel.add(inner, BorderLayout.CENTER);
                } else {
                    JLabel err = new JLabel("QR unavailable - use browser button", SwingConstants.CENTER);
                    err.setFont(new Font("Segoe UI", Font.ITALIC, 12));
                    err.setForeground(new Color(150, 150, 150));
                    qrDisplayPanel.add(err, BorderLayout.CENTER);
                }
                qrDisplayPanel.revalidate(); qrDisplayPanel.repaint();
            });
        } catch (Exception e) {
            SwingUtilities.invokeLater(() -> {
                qrDisplayPanel.removeAll();
                JLabel err = new JLabel("Offline - use 'Open QR in Browser'", SwingConstants.CENTER);
                err.setFont(new Font("Segoe UI", Font.ITALIC, 12));
                qrDisplayPanel.add(err, BorderLayout.CENTER);
                qrDisplayPanel.revalidate(); qrDisplayPanel.repaint();
            });
        }
    }

    private void lookupBook(String isbn) {
        try {
            MongoCollection<Document> books = DatabaseConnection.getCollection("books");
            if (books == null) { SwingUtilities.invokeLater(() -> showStatus("❌ DB error", new Color(231,76,60))); return; }
            Document book = books.find(Filters.eq("isbn", isbn)).first();

            SwingUtilities.invokeLater(() -> {
                resultPanel.removeAll();
                if (book != null) {
                    buildBookCard(book, isbn);
                    showStatus("✔ Book found!", new Color(39, 174, 96));
                } else {
                    showNotFoundCard(isbn);
                    showStatus("✘ No book for ISBN: " + isbn, new Color(231, 76, 60));
                }
                resultPanel.revalidate(); resultPanel.repaint();
            });
        } catch (Exception e) {
            SwingUtilities.invokeLater(() -> showStatus("❌ Error: " + e.getMessage(), new Color(231,76,60)));
        }
    }

    private void buildBookCard(Document book, String isbn) {
        String title    = book.getString("title");
        String author   = book.getString("author");
        String category = book.getString("category") != null ? book.getString("category") : "General";
        String shelf    = book.getString("shelf_location") != null ? book.getString("shelf_location") : "N/A";
        int    qty      = book.getInteger("quantity", 0);
        int    avail    = book.getInteger("available_quantity", 0);
        boolean isAvail = avail > 0;

        // Banner
        JPanel banner = new JPanel(new BorderLayout());
        banner.setBackground(isAvail ? new Color(212,239,223) : new Color(250,219,216));
        banner.setBorder(BorderFactory.createEmptyBorder(12, 10, 12, 10));
        banner.setMaximumSize(new Dimension(Integer.MAX_VALUE, 55));
        JLabel bl = new JLabel(isAvail ? "✔ AVAILABLE — " + avail + " of " + qty + " copies free"
                                       : "✘ NOT AVAILABLE — All copies issued", SwingConstants.CENTER);
        bl.setFont(new Font("Segoe UI", Font.BOLD, 14));
        bl.setForeground(isAvail ? new Color(39,174,96) : new Color(231,76,60));
        banner.add(bl);

        // Detail card
        JPanel card = new JPanel(new GridBagLayout());
        card.setBackground(Color.WHITE);
        card.setBorder(BorderFactory.createCompoundBorder(
            BorderFactory.createLineBorder(new Color(200,200,200), 1, true),
            BorderFactory.createEmptyBorder(15, 20, 15, 20)));
        card.setMaximumSize(new Dimension(Integer.MAX_VALUE, 300));
        GridBagConstraints gbc = new GridBagConstraints();
        gbc.anchor = GridBagConstraints.WEST;
        gbc.insets = new Insets(6, 8, 6, 8);
        gbc.fill = GridBagConstraints.HORIZONTAL;
        addRow(card, gbc, 0, "📖 Title",      title    != null ? title    : "N/A");
        addRow(card, gbc, 1, "✍ Author",     author   != null ? author   : "N/A");
        addRow(card, gbc, 2, "🔖 ISBN",       isbn);
        addRow(card, gbc, 3, "📂 Category",   category);
        addRow(card, gbc, 4, "🗂 Shelf",      shelf);
        addRow(card, gbc, 5, "📦 Total",      qty + " copies");
        addRow(card, gbc, 6, "✅ Available",  avail + " copies");

        // Borrow button
        JPanel actionPanel = new JPanel(new FlowLayout(FlowLayout.CENTER));
        actionPanel.setBackground(Color.WHITE);
        actionPanel.setBorder(BorderFactory.createCompoundBorder(
            BorderFactory.createLineBorder(new Color(200,200,200), 1, true),
            BorderFactory.createEmptyBorder(8, 8, 8, 8)));
        actionPanel.setMaximumSize(new Dimension(Integer.MAX_VALUE, 60));

        if (isAvail) {
            JButton borrowBtn = makeBtn("📚 Request to Borrow", new Color(41, 128, 185));
            String bookId = book.getObjectId("_id").toString();
            borrowBtn.addActionListener(e -> requestBorrow(bookId, title));
            actionPanel.add(borrowBtn);
        } else {
            JLabel notAvailLbl = new JLabel("This book is currently not available");
            notAvailLbl.setFont(new Font("Segoe UI", Font.ITALIC, 13));
            notAvailLbl.setForeground(new Color(150, 150, 150));
            actionPanel.add(notAvailLbl);
        }

        resultPanel.add(Box.createRigidArea(new Dimension(0, 8)));
        resultPanel.add(banner);
        resultPanel.add(Box.createRigidArea(new Dimension(0, 8)));
        resultPanel.add(card);
        resultPanel.add(Box.createRigidArea(new Dimension(0, 8)));
        resultPanel.add(actionPanel);
    }

    private void addRow(JPanel p, GridBagConstraints gbc, int row, String label, String value) {
        gbc.gridx = 0; gbc.gridy = row; gbc.weightx = 0;
        JLabel l = new JLabel(label + ":"); l.setFont(new Font("Segoe UI", Font.BOLD, 13));
        l.setForeground(new Color(100, 100, 100)); p.add(l, gbc);
        gbc.gridx = 1; gbc.weightx = 1;
        JLabel v = new JLabel(value); v.setFont(new Font("Segoe UI", Font.PLAIN, 13));
        v.setForeground(new Color(44, 62, 80)); p.add(v, gbc);
    }

    private void requestBorrow(String bookId, String title) {
        int confirm = JOptionPane.showConfirmDialog(this,
            "Request to borrow:\n\"" + title + "\"?", "Confirm Borrow", JOptionPane.YES_NO_OPTION);
        if (confirm != JOptionPane.YES_OPTION) return;
        try {
            MongoCollection<Document> borrowings = DatabaseConnection.getCollection("book_borrowings");
            long already = borrowings.countDocuments(Filters.and(
                Filters.eq("user_id", userId), Filters.eq("book_id", bookId),
                Filters.eq("status", "BORROWED")));
            if (already > 0) { JOptionPane.showMessageDialog(this, "You already have this book!"); return; }

            DatabaseConnection.getCollection("books").updateOne(
                Filters.and(Filters.eq("_id", new ObjectId(bookId)), Filters.gt("available_quantity", 0)),
                Updates.inc("available_quantity", -1));

            Calendar cal = Calendar.getInstance();
            cal.add(Calendar.DAY_OF_MONTH, 14);
            borrowings.insertOne(new Document()
                .append("book_id", bookId).append("user_id", userId).append("title", title)
                .append("borrow_date", new Date()).append("due_date", cal.getTime())
                .append("status", "BORROWED").append("fine_amount", 0.0).append("fine_paid", false));

            JOptionPane.showMessageDialog(this,
                "✔ Borrow request submitted!\nDue in 14 days.", "Success", JOptionPane.INFORMATION_MESSAGE);
            showStatus("✔ Borrowed: " + title, new Color(39, 174, 96));
        } catch (Exception e) {
            JOptionPane.showMessageDialog(this, "Error: " + e.getMessage());
        }
    }

    private void showNotFoundCard(String isbn) {
        JPanel card = new JPanel(new BorderLayout(0, 6));
        card.setBackground(new Color(253, 245, 230));
        card.setBorder(BorderFactory.createCompoundBorder(
            BorderFactory.createLineBorder(new Color(230, 176, 80), 1, true),
            BorderFactory.createEmptyBorder(20, 20, 20, 20)));
        card.setMaximumSize(new Dimension(Integer.MAX_VALUE, 100));
        JLabel msg = new JLabel("No book found for ISBN: " + isbn, SwingConstants.CENTER);
        msg.setFont(new Font("Segoe UI", Font.BOLD, 14)); msg.setForeground(new Color(180,100,0));
        JLabel hint = new JLabel("Check the ISBN and try again.", SwingConstants.CENTER);
        hint.setFont(new Font("Segoe UI", Font.PLAIN, 12)); hint.setForeground(new Color(150,100,0));
        card.add(msg, BorderLayout.CENTER); card.add(hint, BorderLayout.SOUTH);
        resultPanel.add(Box.createRigidArea(new Dimension(0, 10)));
        resultPanel.add(card);
    }

    private void openInBrowser() {
        if (currentISBN.isEmpty()) { showStatus("⚠ Enter ISBN first", new Color(230,126,34)); return; }
        try {
            Desktop.getDesktop().browse(new URI(
                "https://api.qrserver.com/v1/create-qr-code/?size=400x400&data="
                + URLEncoder.encode(currentISBN, "UTF-8") + "&margin=20"));
            showStatus("✔ QR opened in browser!", new Color(39, 174, 96));
        } catch (Exception e) { showStatus("✘ Cannot open browser", new Color(231,76,60)); }
    }

    private void clearAll() {
        isbnField.setText(""); currentISBN = "";
        showPlaceholder();
        qrDisplayPanel.removeAll();
        JLabel ph = new JLabel("QR code will appear here", SwingConstants.CENTER);
        ph.setFont(new Font("Segoe UI", Font.ITALIC, 13)); ph.setForeground(new Color(190,190,190));
        qrDisplayPanel.add(ph, BorderLayout.CENTER);
        qrDisplayPanel.revalidate(); qrDisplayPanel.repaint();
        showStatus("Ready — enter an ISBN to search", new Color(100,100,100));
        isbnField.requestFocus();
    }

    private void showStatus(String msg, Color color) { statusLabel.setText(msg); statusLabel.setForeground(color); }

    private JButton makeBtn(String text, Color bg) {
        JButton b = new JButton(text);
        b.setBackground(bg); b.setForeground(Color.WHITE);
        b.setFont(new Font("Segoe UI", Font.BOLD, 13));
        b.setFocusPainted(false); b.setBorderPainted(false);
        b.setCursor(new Cursor(Cursor.HAND_CURSOR));
        b.setPreferredSize(new Dimension(220, 38));
        b.addMouseListener(new MouseAdapter() {
            public void mouseEntered(MouseEvent e) { b.setBackground(bg.darker()); }
            public void mouseExited (MouseEvent e) { b.setBackground(bg); }
        });
        return b;
    }
}