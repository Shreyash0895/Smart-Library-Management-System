import javax.swing.*;
import javax.swing.table.DefaultTableModel;
import java.awt.*;
import com.mongodb.client.*;
import org.bson.Document;

public class UserApprovalPanel extends JPanel {

    private JTable table;
    private DefaultTableModel model;

    public UserApprovalPanel() {
        setLayout(new BorderLayout());

        JLabel title = new JLabel("Pending User Approvals", SwingConstants.CENTER);
        title.setFont(new Font("Segoe UI", Font.BOLD, 20));
        add(title, BorderLayout.NORTH);

        model = new DefaultTableModel(
                new String[]{"User ID", "Username", "Role", "Approve"}, 0);

        table = new JTable(model);
        add(new JScrollPane(table), BorderLayout.CENTER);

        JButton approveBtn = new JButton("Approve Selected");
        approveBtn.addActionListener(e -> approveUser());

        add(approveBtn, BorderLayout.SOUTH);

        loadUsers();
    }

    private void loadUsers() {
        model.setRowCount(0);

        MongoCollection<Document> users =
                DatabaseConnection.getCollection("users");

        for (Document user : users.find(new Document("isApproved", false))) {

            model.addRow(new Object[]{
                    user.getObjectId("_id").toString(),
                    user.getString("username"),
                    user.getString("role"),
                    "Approve"
            });
        }
    }

    private void approveUser() {
        int row = table.getSelectedRow();

        if (row == -1) {
            JOptionPane.showMessageDialog(this, "Select a user first!");
            return;
        }

        String userId = model.getValueAt(row, 0).toString();

        MongoCollection<Document> users =
                DatabaseConnection.getCollection("users");

        users.updateOne(
                new Document("_id", new org.bson.types.ObjectId(userId)),
                new Document("$set", new Document("isApproved", true))
        );

        JOptionPane.showMessageDialog(this, "User Approved!");

        loadUsers();
    }
}